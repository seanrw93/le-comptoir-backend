{
  "name": "comptoir-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "node --experimental-vm-modules node_modules/jest/bin/jest.js --selectProjects unit",
    "test:integration": "cross-env PG_URL=postgresql://comptoir_user:password123@localhost:5432/comptoir?options=-c%20search_path%3Dcomptoir_test PG_TEST_SCHEMA=comptoir_test node --experimental-vm-modules node_modules/jest/bin/jest.js --selectProjects integration",
    "test:db:setup": "node test/integration/db/provision-schema.mjs"
  },
  "dependencies": {
    "@koa/cors": "^5.0.0",
    "@koa/router": "^12.0.1",
    "dotenv": "^17.4.2",
    "koa": "^2.15.3",
    "koa-bodyparser": "^4.4.1",
    "pg": "^8.22.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/koa": "^2.15.0",
    "@types/koa__cors": "^5.0.0",
    "@types/koa__router": "^12.0.4",
    "@types/koa-bodyparser": "^4.3.12",
    "@types/node": "^22.9.0",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "cross-env": "^10.1.0",
    "jest": "^30.4.2",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
